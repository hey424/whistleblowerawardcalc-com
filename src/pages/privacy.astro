---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Privacy Policy | whistleblowerawardcalc.com';
const description = 'Privacy policy for whistleblowerawardcalc.com — data collection, cookies, Google AdSense and Analytics, and your privacy rights.';
---
<BaseLayout title={title} description={description}>
  <h1>Privacy Policy</h1>
  <p><strong>Effective date:</strong> January 1, 2026</p>
  <p>This privacy policy describes how whistleblowerawardcalc.com collects, uses, and shares information when you use this website.</p>

  <h2>Information We Collect</h2>
  <p>We do not collect personally identifiable information directly. We do not require registration, do not store calculator inputs on our servers, and do not collect your name, email address, or any other identifying information unless you contact us voluntarily. All calculator processing occurs in your browser — no data you enter is transmitted to us. We use Google AdSense and Google Analytics, which may collect usage data as described below.</p>

  <h2>Google Analytics</h2>
  <p>We use Google Analytics 4 for aggregate, anonymized traffic data: pages viewed, session duration, geographic region, device type, and traffic source. This data cannot identify individual visitors. Opt out via the <a href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noopener">Google Analytics opt-out browser add-on</a>.</p>

  <h2>Google AdSense and Cookies</h2>
  <p>We display advertising through Google AdSense (pub ID: ca-pub-6434377544325972). Google AdSense uses cookies to serve interest-based ads based on your prior site visits. Opt out at <a href="https://adssettings.google.com" target="_blank" rel="noopener">Google Ad Settings</a>. See <a href="https://policies.google.com/technologies/partner-sites" target="_blank" rel="noopener">Google's Privacy &amp; Terms</a> for how Google uses data on partner sites.</p>

  <h2>California Privacy Rights (CCPA)</h2>
  <p>California residents may request information about personal data collected, request deletion, and opt out of sale. We do not sell personal information. Contact us at <a href="mailto:hey@theclicklab.agency">hey@theclicklab.agency</a>.</p>

  <h2>Children's Privacy</h2>
  <p>This site is not directed to children under 13. We do not knowingly collect information from children under 13.</p>

  <h2>Changes</h2>
  <p>We may update this policy periodically. The effective date reflects the most recent revision.</p>

  <h2>Contact</h2>
  <p>Questions? Email <a href="mailto:hey@theclicklab.agency">hey@theclicklab.agency</a>.</p>
</BaseLayout>
