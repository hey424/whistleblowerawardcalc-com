---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Privacy Policy | whistleblowerawardcalc.com';
const description = 'Privacy policy for whistleblowerawardcalc.com.';
---
<BaseLayout title={title} description={description}>
  <h1>Privacy Policy</h1>
  <p><strong>Effective date:</strong> January 1, 2026</p>
  <h2>Information we collect</h2><p>We do not collect personal information directly. We use Google AdSense, which may collect usage data per Google&rsquo;s privacy policy.</p>
  <h2>Cookies</h2><p>Google AdSense sets cookies to serve relevant ads. Opt out via <a href="https://adssettings.google.com" target="_blank" rel="noopener">Google Ad Settings</a>.</p>
  <h2>Third-party services</h2><p>Google AdSense and Google Analytics (aggregate traffic). Both subject to Google&rsquo;s <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">Privacy Policy</a>.</p>
  <h2>Contact</h2><p>Questions? Email <a href="mailto:hey@theclicklab.agency">hey@theclicklab.agency</a>.</p>
</BaseLayout>
