---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Editorial Team';
const description = 'The editorial team behind The Click Lab calculator sites.';
---
<BaseLayout title={title} description={description}>
  <h1>Editorial Team</h1>
  <p>All content is written and reviewed by The Click Lab&rsquo;s editorial team before publication.</p>
  <h2>Our standards</h2>
  <ul>
    <li>Every factual claim is sourced to a primary authority (statute, regulation, or published case).</li>
    <li>Calculator formulas are documented on the <a href="/methodology">methodology page</a>.</li>
    <li>Pages are updated when laws or regulations change.</li>
    <li>No sponsored content or paid placements.</li>
  </ul>
  <h2>Corrections</h2><p>Found an error? <a href="/contact">Contact us</a> and we&rsquo;ll review promptly.</p>
</BaseLayout>
